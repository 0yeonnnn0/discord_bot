<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Discord Bot - 대시보드</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav>
    <div class="nav-brand">TORO Bot =^0w0^=</div>
    <div class="nav-links">
      <a href="/">대시보드</a>
      <a href="/logs">로그</a>
      <a href="/settings">설정</a>
    </div>
  </nav>
  <main>
    <div class="dashboard">
      <!-- 상태 카드 -->
      <h1>봇 상태</h1>
      <div class="cards">
        <div class="card">
          <div class="card-label">상태</div>
          <div class="card-value <%= online ? 'text-green' : 'text-red' %>">
            <%= online ? '● 온라인' : '○ 오프라인' %>
          </div>
        </div>
        <div class="card">
          <div class="card-label">봇</div>
          <div class="card-value"><%= botTag %></div>
        </div>
        <div class="card">
          <div class="card-label">업타임</div>
          <div class="card-value"><%= Math.floor(uptime / 1000 / 60) %>분</div>
        </div>
        <div class="card">
          <div class="card-label">처리한 메시지</div>
          <div class="card-value"><%= stats.messagesProcessed %></div>
        </div>
        <div class="card">
          <div class="card-label">봇 응답 수</div>
          <div class="card-value"><%= stats.repliesSent %></div>
        </div>
        <div class="card">
          <div class="card-label">응답 확률</div>
          <div class="card-value"><%= Math.round(config.replyChance * 100) %>%</div>
        </div>
        <div class="card">
          <div class="card-label">RAG 벡터</div>
          <div class="card-value"><%= ragStats.vectorCount %>개</div>
        </div>
      </div>

      <!-- 유저별 통계 -->
      <h2>유저별 통계</h2>
      <% if (userStats.length === 0) { %>
        <p class="hint">아직 데이터가 없다냥</p>
      <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>순위</th>
              <th>유저</th>
              <th>메시지 수</th>
              <th>봇 응답 받은 수</th>
              <th>응답 비율</th>
            </tr>
          </thead>
          <tbody>
            <% userStats.forEach((user, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td><%= user.displayName %></td>
              <td><%= user.messages %></td>
              <td><%= user.gotReplies %></td>
              <td><%= user.messages > 0 ? Math.round(user.gotReplies / user.messages * 100) : 0 %>%</td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>

      <!-- 인기 키워드 -->
      <h2>인기 키워드</h2>
      <% if (keywords.length === 0) { %>
        <p class="hint">아직 데이터가 없다냥</p>
      <% } else { %>
      <div class="keyword-cloud">
        <% const maxCount = keywords[0]?.count || 1; %>
        <% keywords.forEach(kw => { %>
          <% const size = 0.7 + (kw.count / maxCount) * 1.3; %>
          <span class="keyword" style="font-size: <%= size %>rem" title="<%= kw.count %>회">
            <%= kw.word %>
          </span>
        <% }) %>
      </div>
      <% } %>
    </div>
  </main>
</body>
</html>
